@page
@model IndexModel
@using aitest3.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@{
    ViewData["Title"] = "Card Collection";
}

<div class="container-fluid">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Card Collection</a>
            <div class="ms-auto">
                @if (SignInManager.IsSignedIn(User))
                {
                    <span class="text-white me-3">Welcome, <strong>@User.Identity.Name</strong></span>
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-light me-2">Profile</a>
                    <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="d-inline">
                        <button type="submit" class="btn btn-outline-light">Logout</button>
                    </form>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-light me-2">Login</a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light">Register</a>
                }
            </div>
        </div>
    </nav>
</div>

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h1 class="display-4">Your Card Collection</h1>
            <p class="lead">Manage and view your hockey card collection</p>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-8">
            <h2>Your Cards</h2>
            @if (Model.UserCards.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Card Number</th>
                                <th>Player Name</th>
                                <th>Team</th>
                                <th>Set Name</th>
                                <th>Rookie</th>
                                <th>Short Print</th>
                                <th>Added Date</th>
                                <th>Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var card in Model.UserCards)
                            {
                                <tr>
                                    <td>@(card.CardNumber ?? "N/A")</td>
                                    <td>@(card.PlayerName ?? "N/A")</td>
                                    <td>@((card.TeamCity ?? "") + (string.IsNullOrEmpty(card.TeamName) ? "" : " " + card.TeamName))</td>
                                    <td>@(card.SetName ?? "N/A")</td>
                                    <td>
                                        @if (card.Rookie == true)
                                        {
                                            <span class="badge bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>
                                    <td>
                                        @if (card.ShortPrint == true)
                                        {
                                            <span class="badge bg-warning">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>
                                    <td>@card.AddedAt.ToString("g")</td>
                                    <td>
                                        <span class="badge bg-info">@card.Count</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <p class="mt-3"><strong>Total Unique Cards: @Model.UserCards.Count</strong> | <strong>Total Cards: @Model.UserCards.Sum(c => c.Count)</strong></p>
            }
            else
            {
                <div class="alert alert-info">
                    <p>You don't have any cards in your collection yet.</p>
                </div>
            }
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Collection Stats</h5>
                    <p>
                        <strong>Total Cards:</strong><br />
                        @if (Model.UserCards.Any())
                        {
                            <span class="h4">@Model.UserCards.Sum(c => c.Count)</span>
                        }
                        else
                        {
                            <span class="h4">0</span>
                        }
                    </p>
                    <p>
                        <strong>Unique Cards:</strong><br />
                        <span class="h4">@Model.UserCards.Count</span>
                    </p>
                    @if (Model.UserCards.Any())
                    {
                        var rookieCount = Model.UserCards.Count(c => c.Rookie == true);
                        <p>
                            <strong>Rookie Cards:</strong><br />
                            <span class="h4">@rookieCount</span>
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
